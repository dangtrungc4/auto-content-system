generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Config {
  id                Int     @id @default(1)
  cronSchedule      String? @default("* * * * *")
  sheetId           String?
  googleClientEmail String?
  googlePrivateKey  String? @db.Text
  fbAppId           String?
  fbPageToken       String? @db.Text
  unsplashKey       String?
  fbPageId          String?
  fbUserToken       String? @db.Text
  fbAppSecret       String?
  isAutoSyncEnabled Boolean @default(false)
  bannedWords       String? @db.Text
  geminiApiKey      String? @db.Text
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now())
  posts     Post[]   @relation("PostToTag")

  @@map("tags")
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String?   @db.Text
  content     String?   @db.Text
  caption     String?   @db.Text
  imageUrl    String?   @db.Text
  status      String?   @default("DRAFT")
  fbPostId    String?   @unique
  scheduledAt DateTime?
  publishedAt DateTime?
  likes       Int       @default(0)
  comments    Int       @default(0)
  shares      Int       @default(0)
  authorId    Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hashtag     String?   @db.Text
  topic       String?   @db.Text
  location    String?   @db.Text
  sheetRow    Int?      @unique
  type        String?   @default("POST")
  tags        Tag[]     @relation("PostToTag")

  @@map("posts")
}

model PromptCategory {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  createdAt DateTime        @default(now())
  keywords  PromptKeyword[]

  @@map("prompt_categories")
}

model PromptKeyword {
  id          Int            @id @default(autoincrement())
  name        String
  label       String?
  description String?        @db.Text
  categoryId  Int
  createdAt   DateTime       @default(now())
  category    PromptCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "prompt_keywords_categoryId_fkey")
  @@map("prompt_keywords")
}

model PromptHistory {
  id        Int      @id @default(autoincrement())
  prompt    String   @db.Text
  createdAt DateTime @default(now())

  @@map("prompt_history")
}
